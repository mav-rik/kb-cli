{
  "name": "kb-wiki",
  "version": "0.1.4",
  "description": "Knowledge base CLI for AI agents",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "kb": "./bin.js"
  },
  "files": [
    "dist",
    "bin.js",
    "content"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rolldown build -c rolldown.config.ts",
    "dev": "pnpm build && node ./dist/main.js",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "wiki",
    "knowledge-base",
    "ai",
    "llm",
    "memory",
    "cli",
    "semantic-search",
    "markdown"
  ],
  "author": "Artem Maltsev <artem@maltsev.nl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mav-rik/kb-cli.git"
  },
  "homepage": "https://github.com/mav-rik/kb-cli#readme",
  "bugs": {
    "url": "https://github.com/mav-rik/kb-cli/issues"
  },
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@atscript/core": "^0.1.53",
    "@atscript/db": "^0.1.74",
    "@atscript/db-sqlite": "^0.1.74",
    "@atscript/typescript": "^0.1.53",
    "@huggingface/transformers": "^4.2.0",
    "@moostjs/event-cli": "^0.6.9",
    "@moostjs/event-http": "^0.6.9",
    "better-sqlite3": "^12.9.0",
    "gray-matter": "^4.0.3",
    "moost": "^0.6.9",
    "sqlite-vec": "^0.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "onnxruntime-node"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "rolldown": "1.0.0",
    "typescript": "^6.0.3",
    "unplugin-atscript": "^0.1.53",
    "vitest": "^4.1.5"
  }
}